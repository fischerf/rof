# ============================================================================
# ROF Bot Dashboard Client — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# Variables prefixed with VITE_ are exposed to the browser bundle at
# build time via import.meta.env.  Never put secrets here.
#
# Usage:
#   cp .env.example .env.local
#   # edit .env.local
#   npm run dev
# ============================================================================

# ---------------------------------------------------------------------------
# API base URL
# ---------------------------------------------------------------------------
# The base URL for the bot-service FastAPI backend.
# In development with Vite proxy (default), leave this empty — the proxy
# in vite.config.ts forwards all API calls to http://localhost:8080.
#
# In production (Docker / nginx), set this to the fully-qualified URL of
# the backend so the nginx proxy or the SPA can reach it directly.
#
# Examples:
#   VITE_API_BASE=                          # empty = use Vite dev proxy
#   VITE_API_BASE=http://localhost:8080     # direct to local backend
#   VITE_API_BASE=https://rof-bot.internal  # production backend
VITE_API_BASE=

# ---------------------------------------------------------------------------
# WebSocket feed URL (optional override)
# ---------------------------------------------------------------------------
# By default the dashboard derives the WebSocket URL from window.location:
#   ws://localhost:3000/ws/feed  (dev)
#   wss://your-domain.com/ws/feed  (prod HTTPS)
#
# Set this only if your WebSocket endpoint is on a different host/port.
#
# Examples:
#   VITE_WS_URL=                            # empty = derive from window.location
#   VITE_WS_URL=ws://localhost:8080/ws/feed
#   VITE_WS_URL=wss://rof-bot.internal/ws/feed
VITE_WS_URL=

# ---------------------------------------------------------------------------
# Status polling interval (milliseconds)
# ---------------------------------------------------------------------------
# How often the dashboard polls GET /status to refresh the navbar status pill.
# Default: 3000 (3 seconds)
# Increase this value to reduce load on the backend in low-resource environments.
VITE_STATUS_POLL_MS=3000

# ---------------------------------------------------------------------------
# Routing heatmap refresh interval (milliseconds)
# ---------------------------------------------------------------------------
# How often the Routing Memory Heatmap view refreshes from the backend.
# Default: 30000 (30 seconds)
VITE_ROUTING_POLL_MS=30000

# ---------------------------------------------------------------------------
# Run list refresh interval (milliseconds)
# ---------------------------------------------------------------------------
# How often the Run Inspector view polls GET /runs for new entries.
# Default: 10000 (10 seconds)
VITE_RUNS_POLL_MS=10000

# ---------------------------------------------------------------------------
# Max WebSocket events buffered in memory
# ---------------------------------------------------------------------------
# The Live Monitor keeps a circular buffer of the most recent WebSocket events.
# Increase if you want a longer history in the feed; decrease to save memory.
# Default: 500
VITE_WS_MAX_EVENTS=500

# ---------------------------------------------------------------------------
# App title (used in document.title)
# ---------------------------------------------------------------------------
# Override the browser tab title shown for the dashboard.
# Default: ROF Bot — Dashboard
VITE_APP_TITLE=ROF Bot — Dashboard

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Enable the "Replay in CLI" button (requires the rof CLI to be installed).
# Default: true
VITE_FEATURE_REPLAY=true

# Show the raw JSON tab in the Run Inspector entity browser.
# Default: true
VITE_FEATURE_RAW_JSON=true

# Enable the snapshot diff feature (requires two runs to be selected as A/B).
# Default: true
VITE_FEATURE_SNAPSHOT_DIFF=true

# Show the Grafana iframe embed panel in the Metrics view when a URL is set.
# Default: false (native Recharts panels are shown instead)
VITE_FEATURE_GRAFANA_EMBED=false

# ---------------------------------------------------------------------------
# Grafana embed URL (only used when VITE_FEATURE_GRAFANA_EMBED=true)
# ---------------------------------------------------------------------------
# The full URL of the Grafana dashboard to embed in the Metrics view.
# The dashboard must be publicly accessible or the operator must be
# authenticated with Grafana in their browser session.
#
# Example:
#   VITE_GRAFANA_URL=http://grafana.internal:3000/d/rof-bot/rof-bot-metrics?orgId=1&kiosk
VITE_GRAFANA_URL=

# ---------------------------------------------------------------------------
# Build / deploy metadata (injected at build time — do not set manually)
# ---------------------------------------------------------------------------
# These are typically set by CI/CD pipelines via --env flags or build args
# and are displayed in the dashboard footer.
#
# VITE_GIT_COMMIT=abc1234
# VITE_BUILD_DATE=2025-08-01T12:00:00Z
# VITE_VERSION=1.0.0
