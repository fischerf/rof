# ============================================================================
# ROF Bot Dashboard Client — .gitignore
# ============================================================================

# ── Node / npm ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
.npm/

# ── Build output ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ── Vite cache ───────────────────────────────────────────────────────────────
.vite/
vite.config.ts.timestamp-*

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Environment files ─────────────────────────────────────────────────────────
# Never commit .env files — use .env.example as a template
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.swn
*~

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Test / coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
playwright/.cache/

# ── ESLint / lint cache ───────────────────────────────────────────────────────
.eslintcache
.stylelintcache

# ── Storybook ─────────────────────────────────────────────────────────────────
storybook-static/
.storybook-build/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Temp files ────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ── Lock files — keep package-lock.json, ignore others ───────────────────────
yarn.lock
pnpm-lock.yaml

# ── Docker ────────────────────────────────────────────────────────────────────
# (Dockerfile and nginx.conf.template are committed)
.dockerignore.local
