# =============================================================================
# ROF Bot — Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------
ROF_PROVIDER=anthropic
ROF_MODEL=claude-sonnet-4-6
ROF_API_KEY=sk-ant-...

# Override model for the decide stage (more powerful / more expensive)
ROF_DECIDE_MODEL=claude-opus-4-6

# -----------------------------------------------------------------------------
# External System Credentials
# Domain-specific — fill in per deployment.
# -----------------------------------------------------------------------------
EXTERNAL_API_KEY=
EXTERNAL_API_BASE_URL=https://api.example.com

# External signal source (optional — used by ExternalSignalTool)
EXTERNAL_SIGNAL_API_KEY=
EXTERNAL_SIGNAL_BASE_URL=https://signals.example.com
SIGNAL_CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Storage — SQLAlchemy is the default DB backend
# -----------------------------------------------------------------------------
# SQLite (default — no extra services needed for local dev)
DATABASE_URL=sqlite:///./rof_bot.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://bot:bot@localhost:5432/rof_bot

# Async variant used by the FastAPI service for CRUD paths
# (asyncpg driver — only needed when DATABASE_URL is postgres)
# ASYNC_DATABASE_URL=postgresql+asyncpg://bot:bot@localhost:5432/rof_bot

REDIS_URL=redis://localhost:6379/0
CHROMADB_PATH=./data/chromadb

# -----------------------------------------------------------------------------
# Bot Behaviour
# -----------------------------------------------------------------------------
BOT_CYCLE_TRIGGER=interval              # interval | event | cron
BOT_CYCLE_INTERVAL_SECONDS=60
BOT_CYCLE_CRON=                         # e.g. "*/5 * * * *" — only when trigger=cron

# Comma-separated list of domain subjects to fan-out per cycle
BOT_TARGETS=target_a

# Dry-run mode — keep true until production graduation checklist is complete
BOT_DRY_RUN=true
BOT_DRY_RUN_MODE=log_only              # log_only | mock_actions | shadow

# -----------------------------------------------------------------------------
# Operational Limits
# -----------------------------------------------------------------------------
BOT_MAX_CONCURRENT_ACTIONS=5
BOT_DAILY_ERROR_BUDGET=0.05            # fraction of cycles allowed to fail (0.0–1.0)
BOT_RESOURCE_UTILISATION_LIMIT=0.80   # generic capacity cap (0.0–1.0)

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Required header value for /control/emergency-stop
OPERATOR_KEY=change-me-in-production

# API key required for all /control/* write endpoints (Bearer token)
API_KEY=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Service
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080

# Routing memory checkpoint interval (minutes)
ROUTING_MEMORY_CHECKPOINT_MINUTES=5
